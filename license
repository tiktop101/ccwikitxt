-- CC vs DirectGPU Speed Benchmark
-- Tests raw math and execution throughput

local function yieldSafe()
-- Yields the coroutine for exactly 1 tick to prevent
-- the "Too long without yielding" crash during heavy math.
os.queueEvent("benchmark_yield")
os.pullEvent("benchmark_yield")
end

term.clear()
term.setCursorPos(1,1)
print("--- Execution Speed Benchmark ---")
print("Running heavy calculations...")
print("Please wait...\n")

-- Use absolute real-world UTC time AND CPU clock time
local startRealTime = os.epoch("utc")
local startCpuTime = os.clock()

-- ==========================================
-- TEST 1: Prime Numbers
-- ==========================================
-- Increased to 250,000 to make the benchmark harder
print("[1/3] Calculating primes to 250,000...")
local primeCount = 0
for i = 2, 250000 do
    local isPrime = true
    local limit = math.sqrt(i)
    for j = 2, limit do
        if i % j == 0 then
            isPrime = false
            break
            end
            end
            if isPrime then primeCount = primeCount + 1 end

                -- Yield every 10,000th iteration
                if i % 10000 == 0 then yieldSafe() end
                    end

                    -- ==========================================
                    -- TEST 2: Collatz Conjecture (3x + 1)
                    -- ==========================================
                    -- Increased to 100,000
                    print("[2/3] Simulating Collatz to 100,000...")
                    local longestStep = 0
                    for i = 1, 100000 do
                        local steps = 0
                        local n = i
                        while n ~= 1 do
                            if n % 2 == 0 then
                                n = n / 2
                                else
                                    n = 3 * n + 1
                                    end
                                    steps = steps + 1
                                    end
                                    if steps > longestStep then longestStep = steps end

                                        -- Yield every 5,000th iteration
                                        if i % 5000 == 0 then yieldSafe() end
                                            end

                                            -- ==========================================
                                            -- TEST 3: Pi Approximation
                                            -- ==========================================
                                            -- Increased to 10 Million loops
                                            print("[3/3] Approximating Pi (10M loops)...")
                                            local pi = 0
                                            for i = 0, 10000000 do
                                                local term = 1 / (2 * i + 1)
                                                if i % 2 == 0 then
                                                    pi = pi + term
                                                    else
                                                        pi = pi - term
                                                        end

                                                        -- Yield every 250,000th iteration
                                                        if i % 250000 == 0 then yieldSafe() end
                                                            end
                                                            pi = pi * 4

                                                            -- ==========================================
                                                            -- TEST 4: Event/Tick Throughput
                                                            -- ==========================================
                                                            print("[4/4] Testing Tick Speed (1,000 yields)...")
                                                            local tickTestStart = os.epoch("utc")

                                                            for i = 1, 1000 do
                                                                -- This forces the coroutine to yield to the Java backend.
                                                                -- Standard CC can do this 20 times a second.
                                                                -- Your modded shell should do this 100 times a second!
                                                                os.queueEvent("throughput_test")
                                                                os.pullEvent("throughput_test")
                                                                end
                                                                local tickTestEnd = os.epoch("utc")
                                                                local tickDuration = (tickTestEnd - tickTestStart) / 1000

                                                                -- Calculate absolute elapsed times
                                                                local endRealTime = os.epoch("utc")
                                                                local endCpuTime = os.clock()

                                                                local durationReal = (endRealTime - startRealTime) / 1000
                                                                local durationCpu = endCpuTime - startCpuTime

                                                                print("\n--- Benchmark Complete ---")
                                                                print(string.format("Math Real Time : %.2f seconds", durationReal - tickDuration))
                                                                print(string.format("Math CPU Time  : %.2f seconds", durationCpu))
                                                                print(string.format("Yielding Time  : %.2f seconds", tickDuration))
                                                                print("--------------------------")
                                                                print("Run this on both the DirectGPU shell")
                                                                print("and a normal CC computer to compare!")
